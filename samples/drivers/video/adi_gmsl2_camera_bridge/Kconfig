mainmenu "GMSL2 Camera Bridge Sample"

config APP_TPG_MODE
	bool "MAX96724 internal Video Pattern Generator validation mode"
	help
	  Build the sample as a minimal capture-to-display loop sourced from
	  the MAX96724 internal Video Pattern Generator (VPG / "TPG"),
	  bypassing the GMSL link, serializer and camera sensor. Used to
	  validate the host-side CSI-2 + DCMIPP + display path in isolation.

config APP_TEST_PATTERN
	int "Test pattern index (0 = off)"
	default 0
	help
	  Set the VIDEO_CID_TEST_PATTERN control on the sensor at startup.
	  0 disables the test pattern (normal sensor output).
	  Sensor-specific values: for IMX219, 2 = 100%% color bars.

source "Kconfig.zephyr"

module = APP
module-str = Application
source "subsys/logging/Kconfig.template.log_config"
