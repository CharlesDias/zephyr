/* Board-specific configuration for STM32U5G9J-DK1 MIPI DSI sample */

#include <zephyr/dt-bindings/display/panel.h>
#include <zephyr/dt-bindings/mipi_dsi/mipi_dsi.h>

/ {
	chosen {
		/* Ensure we have enough stack space for HAL operations */
		zephyr,main-stack-size = <8192>;
		zephyr,display = &ltdc;
	};

	// reserved-memory {
	// 	#address-cells = <1>;
	// 	#size-cells = <1>;

	// 	/* Frame buffer memory region for LTDC - 480x481x4 bytes */
	// 	ltdc_fb: ltdc_framebuffer@200d0000 {
	// 		compatible = "zephyr,memory-region";
	// 		reg = <0x200d0000 0x95000>; /* 924480 bytes */
	// 		zephyr,memory-region = "LTDC_FB";
	// 	};
	// };

	mipi_dsi: dsihost@40016c00 {
		compatible = "st,stm32-mipi-dsi";
		// compatible = "st,stm32-custom-mipi-dsi";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0x40016C00 0x1000>;
		clock-names = "dsiclk", "refclk", "pixelclk";
		clocks = <&rcc STM32_CLOCK(APB2, 27U)>,
				<&rcc STM32_SRC_HSE NO_SEL>,
				<&rcc STM32_SRC_PLL3_P NO_SEL>;
		resets = <&rctl STM32_RESET(APB2, 27U)>;
		status = "disabled";
	};
};

/* Configure USART1 for console output */
&usart1 {
	status = "okay";
};


// &pll2 {
// 	div-m = <4>;    /* Input divider: 16MHz / 4 = 4MHz */
// 	mul-n = <125>;  /* Multiplier: 4MHz * 125 = 500MHz VCO */
// 	div-p = <2>;    /* P output: 500MHz / 2 = 250MHz */
// 	div-q = <2>;    /* Q output: 500MHz / 2 = 250MHz */
// 	div-r = <24>;   /* R output: 500MHz / 24 = 20.83MHz */
// 	clocks = <&clk_hse>;
// 	status = "okay";
// };

/* PLL3 configuration for DSI - based on STM32CubeU5 working configuration */
&pll3 {
	div-m = <4>;    /* Input divider: 16MHz / 4 = 4MHz */
	mul-n = <125>;  /* Multiplier: 4MHz * 125 = 500MHz VCO */
	div-p = <8>;    /* P output: 500MHz / 8 = 62.5MHz (for DSI pixel clock) */
	div-q = <2>;    /* Q output: 500MHz / 2 = 250MHz */
	div-r = <24>;   /* R output: 500MHz / 24 = 20.83MHz (for LTDC) */
	clocks = <&clk_hse>;
	status = "okay";
};

&mipi_dsi {
	status = "okay";

	/* DSI PLL configuration - values from STM32CubeU5 working config */
	pll-ndiv = <125>;     /* PLLDSINDIV = 125 */
	pll-idf = <4>;        /* DSI_PLL_IN_DIV4 */
	pll-odf = <2>;        /* DSI_PLL_OUT_DIV2 */

	/* DSI signal polarity configuration matching STM32CubeU5 */
	hs-active-high;       /* Horizontal sync active high */
	vs-active-high;       /* Vertical sync active high */
	de-active-high;       /* Data enable active high */
	largest-packet-size = <0>;

	/* DSI HOST timeout parameters - based on STM32CubeU5 DSI_VideoMode_SingleBuffer */
	host-timeouts = <1>,     /* TimeoutCkdiv = 1 */
	                <0>,     /* HighSpeedTransmissionTimeout = 0 (default/disabled) */
	                <0>,     /* LowPowerReceptionTimeout = 0 (default/disabled) */
	                <0>,     /* HighSpeedReadTimeout = 0 (default/disabled) */
	                <0>,     /* LowPowerReadTimeout = 0 (default/disabled) */
	                <0>,     /* HighSpeedWriteTimeout = 0 (default/disabled) */
	                <0>,     /* HighSpeedWritePrespMode = 0 (DSI_HS_PM_DISABLE) */
	                <0>,     /* LowPowerWriteTimeout = 0 (default/disabled) */
	                <0>;     /* BTATimeout = 0 (default/disabled) */

	/* DSI HOST timing parameters from STM32CubeU5 working configuration */
	phy-timings = <11>,   /* ClockLaneHS2LPTime = 11 */
	              <40>,   /* ClockLaneLP2HSTime = 40 */
	              <12>,   /* DataLaneHS2LPTime = 12 */
	              <23>,   /* DataLaneLP2HSTime = 23 */
	              <0>,    /* DataLaneMaxReadTime = 0 (default) */
	              <7>;    /* StopWaitTime = 7 */

	// /* TX Escape Clock Divider - exact value from STM32CubeU5 reference */
	// tx-escape-clk-div = <4>;

	/* HX8379C panel configuration for STM32U5G9J-DK1 */
	hx8379c: hx8379c@0 {
		status = "okay";
		compatible = "himax,hx8379c";
		reg = <0>; /* Virtual channel 0 */

		/* Panel specifications - matching STM32CubeU5 exactly */
		width = <480>;
		height = <481>;  /* Must match LTDC height for STM32CubeU5 compatibility */

		/* DSI configuration matching STM32CubeU5 working example */
		data-lanes = <2>; /* DSI_TWO_DATA_LANES = 1 in STM32 HAL */
		pixel-format = <MIPI_DSI_PIXFMT_RGB888>;

		reset-gpios = <&gpiod 5 GPIO_ACTIVE_HIGH>;  /* PD5 - confirmed from STM32 DSI example */
		bl-gpios = <&gpioi 6 GPIO_ACTIVE_HIGH>;    /* PI6 - confirmed from STM32 DSI example */
	};
};

&ltdc {
	// compatible = "st,stm32-ltdc-custom";
	width = <480>;
	height = <481>;
	pixel-format = <0>; /* LTDC_PIXEL_FORMAT_ARGB8888 */
	status = "okay";

	def-back-color-red = <0>;
	def-back-color-green = <0>;
	def-back-color-blue = <0>;

	/* himax,hx8379c */
	display-timings {
		compatible = "zephyr,panel-timing";
		hsync-active = <1>;
		vsync-active = <1>;
		de-active = <0>;
		pixelclk-active = <0>;
		hsync-len = <2>;
		vsync-len = <1>;
		hback-porch = <1>;
		vback-porch = <12>;
		hfront-porch = <1>;
		vfront-porch = <50>;
	};
};
