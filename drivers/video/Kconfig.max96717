config VIDEO_MAX96717
	bool "ADI MAX96717 GMSL2 serializer"
	select I2C
	depends on DT_HAS_ADI_MAX96717_ENABLED
	default y
	help
	  Enable driver for the ADI MAX96717 GMSL2 serializer.
	  The MAX96717 receives MIPI CSI-2 data from a camera sensor
	  and transmits it over a coaxial GMSL2 link.

if VIDEO_MAX96717

config VIDEO_MAX96717_INIT_PRIORITY
	int "MAX96717 init priority"
	default 59
	help
	  Initialization priority for the MAX96717 serializer. This should be
	  higher than the deserializer's and lower than camera sensor priority
	  to ensure proper initialization order.

config VIDEO_MAX96717_PATGEN_ENABLE
	bool "Enable MAX96717 internal Video Pattern Generator (PATGEN)"
	default n
	help
	  Configure the MAX96717's internal pattern generator at probe time
	  to emit a synthetic 800x480 RGB888 frame over GMSL. Used to
	  validate the full SerDes path when no real image sensor is wired
	  to the serializer.

choice VIDEO_MAX96717_PATGEN_PATTERN
	prompt "MAX96717 PATGEN test pattern"
	depends on VIDEO_MAX96717_PATGEN_ENABLE
	default VIDEO_MAX96717_PATGEN_PATTERN_GRADIENT

config VIDEO_MAX96717_PATGEN_PATTERN_GRADIENT
	bool "Color gradient"

config VIDEO_MAX96717_PATGEN_PATTERN_CHECKERBOARD
	bool "Checkerboard"

endchoice

endif
